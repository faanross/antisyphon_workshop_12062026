# Model names change over time. Use a valid model ID for the selected provider.
# API model catalogs:
# Gemini: https://ai.google.dev/gemini-api/docs/models
# OpenAI: https://developers.openai.com/api/docs/models
# Anthropic: https://docs.anthropic.com/en/docs/about-claude/models/overview
#
# Important:
# - API providers use API model IDs.
# - CLI providers may also support CLI aliases, e.g. Claude Code accepts "sonnet" and "opus".

LLM_PROVIDER=gemini

GEMINI_API_KEY=paste-your-key-here
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-pro

ANTHROPIC_API_KEY=paste-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=paste-your-key-here
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_MODEL=gpt-4.1

CODEX_MODEL=gpt-4.1
# CODEX_MODEL=gpt-4.1-mini

CLAUDE_CODE_MODEL=sonnet
# CLAUDE_CODE_MODEL=opus
# CLAUDE_CODE_MODEL=claude-sonnet-4-6
